# MCP Excel Server Configuration
# Copy this file to .env and modify as needed

# Transport: "stdio" for local, "http" for remote
MCP_EXCEL_TRANSPORT=stdio

# Error handling: mask internal errors in production
MCP_EXCEL_MASK_ERRORS=true

# Security: allowed directories for file access (empty = no restriction)
# Example: MCP_EXCEL_ALLOWED_DIRECTORIES=["/home/user/documents", "/data"]
MCP_EXCEL_ALLOWED_DIRECTORIES=[]

# Cache settings
MCP_EXCEL_CACHE_SIZE=5
MCP_EXCEL_CACHE_MEMORY_MB=1024

# Pagination: max cells per page
MCP_EXCEL_PAGING_LIMIT=4000

# Response limits
MCP_EXCEL_MAX_ROWS=500
MCP_EXCEL_MAX_COLUMNS=50

# Logging
MCP_EXCEL_LOG_LEVEL=INFO

# VBA settings (requires xlwings: pip install 'mcp-excel-server[vba]')
MCP_EXCEL_VBA_ENABLED=true
MCP_EXCEL_VBA_MACRO_TIMEOUT=30
MCP_EXCEL_VBA_TRUST_ACCESS=false
MCP_EXCEL_VBA_SHOW_EXCEL=false
MCP_EXCEL_VBA_AUDIT_LOG=true
